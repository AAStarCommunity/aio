# Node Configuration
NODE_ID=node1
NODE_URL=http://localhost:3001
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
IS_MASTER_NODE=false

# Ethereum Configuration
ETH_RPC_URL=https://sepolia.infura.io/v3/your-api-key
CHAIN_ID=11155111
# 这个私钥必须是BLSNodeRegistry合约owner的私钥
ETH_PRIVATE_KEY=your-ethereum-private-key
# BLSNodeRegistry合约地址
BLS_NODE_REGISTRY_ADDRESS=your-contract-address

# BLS Configuration
# BLS私钥（用于签名）
BLS_PRIVATE_KEY=your-bls-private-key
# BLS公钥（48字节，用于注册）
BLS_PUBLIC_KEY=your-bls-public-key