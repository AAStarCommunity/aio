{
  "name": "aastar-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "next dev -p 8080",
    "build": "next build",
    "start:prod": "next start -p 8080",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@simplewebauthn/browser": "^8.3.4",
    "autoprefixer": "^10",
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "ethers": "^6.11.1",
    "next": "14.1.0",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "tailwindcss": "^3.4.1",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.24.0",
    "@nestjs/testing": "^11.1.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "ignore-loader": "^0.1.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.2.1",
    "prettier": "^3.2.5",
    "ts-jest": "^29.3.4",
    "typescript": "^5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "@simplewebauthn/browser": "<rootDir>/src/__mocks__/simplewebauthn-browser.ts"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(@simplewebauthn/browser)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.stories.{ts,tsx}"
    ]
  }
}
