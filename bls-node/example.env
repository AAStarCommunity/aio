# 服务器配置
PORT=3001
NODE_ENV=development

# BLS节点配置
NODE_ID=node1
MASTER_NODE_URL=http://localhost:3000
IS_MASTER_NODE=true

# 安全配置
BLS_PRIVATE_KEY=your_bls_private_key_here
RP_ID=localhost
RP_NAME=AAStar
ORIGIN=http://localhost:3000

# 日志配置
LOG_LEVEL=info

# 数据库配置
MONGODB_URL=mongodb://localhost:27017/bls-node

# JWT配置
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h 